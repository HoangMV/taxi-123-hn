/**
 * Tìm file PDF hồ sơ xe mới nhất theo bảng XE.
 */
function findVehiclePdfFileInfo_(idXe) {
  idXe = String(idXe || '').trim();

  const ss = getSpreadsheet_();
  const sh = mustGetSheet_(ss, CONFIG_HOSO_XE.SHEETS.XE);
  ensureColumns_(sh, CONFIG_HOSO_XE.XE_PDF_COLUMNS);

  const values = sh.getDataRange().getDisplayValues();
  const headers = values[0].map(String);

  const colIdXe = headers.indexOf('ID_Xe');
  const colFileId = headers.indexOf('IdFilePDFHoSoXe');
  const colLinkPdf = headers.indexOf('FilePDFHoSoXe');

  if (colIdXe < 0) return { fileId: '' };

  for (let i = 1; i < values.length; i++) {
    if (String(values[i][colIdXe]).trim() === idXe) {
      let fileId = colFileId >= 0 ? String(values[i][colFileId] || '').trim() : '';
      if (!fileId && colLinkPdf >= 0) fileId = extractDriveFileId_(values[i][colLinkPdf]);
      return { fileId: fileId };
    }
  }

  return { fileId: '' };
}


/**
 * Escape chuỗi đưa vào JavaScript string.
 */
function jsString_(value) {
  return String(value || '')
    .replace(/\\/g, '\\\\')
    .replace(/"/g, '\\"')
    .replace(/\n/g, '\\n')
    .replace(/\r/g, '');
}


/****************************************************
 * MỞ HỒ SƠ XE CÔNG KHAI TỪ QR
 *
 * Điều kiện để người quét QR không phải đăng nhập:
 * 1. WebApp deploy dạng /exec.
 * 2. Execute as: Me.
 * 3. Who has access: Anyone.
 * 4. File PDF được setSharing ANYONE_WITH_LINK.
 ****************************************************/
function openVehicleProfilePublic_(idXe, options) {
  options = options || {};
  idXe = String(idXe || '').trim();

  if (!idXe) {
    return htmlMessage_('Thiếu mã xe IDXe.', 'Vui lòng kiểm tra lại QR hoặc đường dẫn mở hồ sơ.');
  }

  const ss = getSpreadsheet_();
  const sh = mustGetSheet_(ss, CONFIG_HOSO_XE.SHEETS.XE);
  ensureColumns_(sh, CONFIG_HOSO_XE.XE_PDF_COLUMNS);

  const values = sh.getDataRange().getDisplayValues();
  const headers = values[0].map(String);

  const colIdXe = headers.indexOf('ID_Xe');
  const colBienSo = headers.indexOf('BienSo');
  const colFileId = headers.indexOf('IdFilePDFHoSoXe');
  const colLinkPdf = headers.indexOf('FilePDFHoSoXe');

  if (colIdXe < 0) {
    return htmlMessage_('Thiếu cột ID_Xe trong bảng XE.', 'Không thể xác định xe từ QR.');
  }

  let row = null;
  for (let i = 1; i < values.length; i++) {
    if (String(values[i][colIdXe]).trim() === idXe) {
      row = values[i];
      break;
    }
  }

  if (!row) {
    return htmlMessage_('Không tìm thấy xe: ' + escapeHtml_(idXe), 'Vui lòng kiểm tra lại mã xe trong QR.');
  }

  let fileId = '';

  if (colFileId >= 0) {
    fileId = String(row[colFileId] || '').trim();
  }

  if (!fileId && colLinkPdf >= 0) {
    fileId = extractDriveFileId_(row[colLinkPdf]);
  }

  if (!fileId) {
    return htmlMessage_(
      'Xe này chưa có hồ sơ PDF.',
      'Vui lòng tạo hồ sơ PDF trước, sau đó quét lại QR.'
    );
  }

  /*
   * Không redirect sang Drive nữa.
   * WebApp đọc file bằng quyền chủ sở hữu rồi nhúng PDF vào HTML.
   * Cách này tránh lỗi "Bạn cần có quyền truy cập" của Google Drive.
   */
  return serveVehiclePdfByWebApp_(fileId, {
    idXe: idXe,
    bienSo: colBienSo >= 0 ? row[colBienSo] : '',
    forceDownload: Boolean(options.download)
  });
}


