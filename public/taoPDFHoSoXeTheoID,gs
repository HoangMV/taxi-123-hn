  return 'SC';
}


function formatWorkPeriod_(startValue, endValue) {
  const start = fmtDate_(startValue);
  const end = fmtDate_(endValue);

  if (start && end && start !== end) return start + ' - ' + end;
  if (start && end && start === end) return start;
  if (start) return start;
  if (end) return end;

  return '';
}


function collectPeriods_(items, type) {
  return uniqueList_(
    (items || [])
      .filter(item => item.type === type)
      .map(item => item.period)
      .filter(Boolean)
  ).join('; ');
}


function collectPlacesFromAnnotated_(items, type) {
  return uniqueList_(
    (items || [])
      .filter(item => item.type === type)
      .map(item => item.place)
      .filter(Boolean)
  ).join('; ');
}


function countType_(items, type) {
  return (items || []).filter(item => item.type === type).length;
}


function appendCell_(oldValue, newValue) {
  if (!oldValue) return newValue;
  if (!newValue) return oldValue;
  return oldValue + '; ' + newValue;
}


function uniqueList_(arr) {
  const seen = {};
  const out = [];

  (arr || []).forEach(v => {
    const s = String(v || '').trim();
    if (!s) return;

    const key = normalizeText_(s);
    if (seen[key]) return;

    seen[key] = true;
    out.push(s);
  });

  return out;
}


function sumNumbers_(arr) {
  return (arr || []).reduce((s, v) => {
    if (v === null || v === undefined || v === '') return s;
    return s + num_(v);
  }, 0);
}


function lastNumber_(arr) {
  for (let i = (arr || []).length - 1; i >= 0; i--) {
    const v = arr[i];
    if (v !== null && v !== undefined && v !== '') return num_(v);
  }
  return 0;
}


function valueOrNull_(v) {
  if (v === null || v === undefined || v === '') return null;
  return v;
}


function maxDateMs_(row, fields) {
  let max = 0;
  (fields || []).forEach(f => {
    const ms = dateMs_(row[f]);
    if (ms > max) max = ms;
  });
  return max;
}


function dateMs_(v) {
  const d = asDate_(v);
  return d ? d.getTime() : 0;
}


function yearOf_(v) {
  const d = asDate_(v);
  return d ? d.getFullYear() : null;
}


function monthOf_(v) {
  const d = asDate_(v);
  return d ? d.getMonth() + 1 : null;
}


function asDate_(v) {
  if (!v) return null;

  if (Object.prototype.toString.call(v) === '[object Date]' && !isNaN(v.getTime())) {
    return v;
  }

  if (typeof v === 'number') {
    return new Date(Math.round((v - 25569) * 86400 * 1000));
  }

  const s = String(v).trim();
  if (!s) return null;

  if (/^\d+(\.\d+)?$/.test(s)) {
    const n = Number(s);
    if (n > 30000) return new Date(Math.round((n - 25569) * 86400 * 1000));
  }

  const m1 = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (m1) return new Date(Number(m1[3]), Number(m1[2]) - 1, Number(m1[1]));

  const m2 = s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
  if (m2) return new Date(Number(m2[1]), Number(m2[2]) - 1, Number(m2[3]));

  const d = new Date(s);
  return isNaN(d.getTime()) ? null : d;
}


function fmtDate_(v) {
  const d = asDate_(v);
  if (!d) return '';
  return Utilities.formatDate(d, CONFIG_HOSO_XE.TIMEZONE, 'dd/MM/yyyy');
}


function fmtDateTime_(v) {
  const d = asDate_(v) || new Date();
  return Utilities.formatDate(d, CONFIG_HOSO_XE.TIMEZONE, 'dd/MM/yyyy HH:mm');
}


function num_(v) {
  if (v === null || v === undefined || v === '') return 0;
  if (typeof v === 'number') return v;

  const s = String(v).replace(/[^\d.-]/g, '');
  const n = Number(s);
  return isNaN(n) ? 0 : n;
}


function formatNumberCell_(v) {
  if (v === null || v === undefined || v === '') return '';

  const n = num_(v);
  return n.toLocaleString('vi-VN');
}


function formatMoney_(v) {
  if (v === null || v === undefined || v === '') return '';

  const n = num_(v);
  return n.toLocaleString('vi-VN') + ' đ';
}


function normalizeKey_(v) {
  return String(v || '')
    .replace(/\s+/g, '')
    .replace(/[.\-_/]/g, '')
    .toUpperCase();
}


function cleanFileName_(v) {
  return String(v || '')
    .trim()
    .replace(/\s+/g, '_')
    .replace(/[\\/:*?"<>|]/g, '')
    .replace(/[.\-]/g, '')
    .toUpperCase();
}


function normalizeText_(v) {
  return String(v || '')
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/đ/g, 'd')
    .replace(/\s+/g, ' ')
    .trim();
}


function escapeHtml_(s) {
  return String(s || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}


function errorMessage_(err) {
  return String(err && err.message ? err.message : err);
}


