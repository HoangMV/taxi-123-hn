      };
    });

  const totalCost = bdscRows.reduce((s, r) => s + num_(r.chiPhiNumber), 0);

  const summary = {
    totalKm: formatNumberCell_(sumNumbers_(kmThangRaw)),
    totalTrips: formatNumberCell_(sumNumbers_(chuyenThangRaw)),
