}


/**
 * Tạo PDF theo lô tùy chọn.
 *
 * @param {number=} batchSize số xe/lần chạy
 * @param {number=} nam năm hồ sơ
 * @param {boolean=} recreate true = tạo lại cả xe đã có PDF
 */
function taoPDFHoSoXeTheoLoTuyChon(batchSize, nam, recreate) {
  batchSize = Number(batchSize || CONFIG_HOSO_XE.DEFAULT_BATCH_SIZE);
  nam = Number(nam || new Date().getFullYear());
  recreate = Boolean(recreate);

  const ss = getSpreadsheet_();
  const xeSheet = mustGetSheet_(ss, CONFIG_HOSO_XE.SHEETS.XE);
  ensureColumns_(xeSheet, CONFIG_HOSO_XE.XE_PDF_COLUMNS);

  const model = loadModel_();

  const xeList = model.tables.XE.rows.filter(r => {
    if (!r.ID_Xe) return false;

    const trangThai = normalizeText_(r.TrangThaiXe);
    const isDangQuanLy =
      !trangThai ||
      trangThai.includes('dang') ||
      trangThai.includes('hoat dong') ||
      trangThai.includes('dang hoat dong');

    const daCoPdf = String(r.FilePDFHoSoXe || '').trim() !== '';

    return isDangQuanLy && (recreate || !daCoPdf);
  });

  let ok = 0;
  let fail = 0;
  const errors = [];

  for (let i = 0; i < xeList.length && ok < batchSize; i++) {
    const xe = xeList[i];

    try {
      const result = createVehicleProfilePdf_(model, xe, nam);

      updateXePdfFields_(xe._rowNumber, {
        FilePDFHoSoXe: result.publicViewUrl || result.url,
        IdFilePDFHoSoXe: result.fileId,
        LinkTaiPDFHoSoXe: result.downloadUrl,
        NamPDFHoSoXe: nam,
        NgayTaoPDFHoSoXe: new Date(),
        TrangThaiTaoPDFHoSoXe: 'Đã tạo',
        GhiChuPDFHoSoXe: 'Tạo thành công: ' + result.fileName
      });

      ok++;

    } catch (err) {
      fail++;
      const msg = (xe.BienSo || xe.ID_Xe) + ': ' + errorMessage_(err);
      errors.push(msg);

      updateXePdfFields_(xe._rowNumber, {
        TrangThaiTaoPDFHoSoXe: 'Lỗi',
        GhiChuPDFHoSoXe: errorMessage_(err)
      });
    }
  }

  const message =
    'Hoàn thành lô tạo hồ sơ xe.\n' +
    'Thành công: ' + ok + '\n' +
    'Lỗi: ' + fail + '\n' +
    'Năm hồ sơ: ' + nam + '\n\n' +
    errors.slice(0, 10).join('\n');

  try {
    SpreadsheetApp.getUi().alert(message);
  } catch (e) {
    Logger.log(message);
  }

  return { ok, fail, errors };
}


