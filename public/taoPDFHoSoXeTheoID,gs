function serveVehicleProfileHtmlForQr_(idXe, nam) {
  idXe = String(idXe || '').trim();
  nam = Number(nam || new Date().getFullYear());

  if (!idXe) {
    return htmlMessage_('Thiếu mã xe IDXe.', 'Vui lòng kiểm tra lại QR hoặc đường dẫn mở hồ sơ.');
  }

  let model, xe;
  try {
    model = loadModel_();
    xe = model.index.XE[idXe];
  } catch (err) {
    return htmlMessage_('Không đọc được dữ liệu hệ thống.', errorMessage_(err));
  }

  if (!xe) {
    return htmlMessage_('Không tìm thấy xe: ' + idXe, 'Vui lòng kiểm tra lại mã xe trong QR.');
  }

  /*
   * Tạo lại nội dung HTML hồ sơ từ template.
   * Đây là bản xem trực tiếp, không phải file PDF.
   */
  const data = buildVehicleProfileData_(model, xe, nam);
  const template = HtmlService.createTemplateFromFile('VehicleProfile');
  template.data = data;

  let profileHtml = template.evaluate().getContent();

  /*
   * Bỏ CSS @page/khổ in nếu có thể gây khó xem trên điện thoại.
   * Đồng thời thêm thanh công cụ tải PDF.
   */
  const toolbar = buildQrMobileToolbar_(idXe, xe.BienSo, nam);
  profileHtml = profileHtml.replace(
    /<body([^>]*)>/i,
    '<body$1>' + toolbar
  );

  profileHtml = profileHtml.replace(
    '</style>',
    buildQrMobileCss_() + '\n</style>'
  );

  return HtmlService
    .createHtmlOutput(profileHtml)
    .setTitle('Hồ sơ xe ' + (xe.BienSo || idXe))
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}


