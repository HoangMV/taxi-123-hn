/**
 * Tạo URL QR dạng SVG.
 * Giải pháp này dùng để nhúng trực tiếp SVG vào HTML, không dùng thẻ <img>.
 */
function buildVehicleQrSvgUrl_(qrText) {
  qrText = String(qrText || '').trim();
  if (!qrText) return '';

  const size = Number(CONFIG_QR_HOSO_XE.QR_SIZE || 320);
  const margin = Number(CONFIG_QR_HOSO_XE.QR_MARGIN || 1);

  return (
    'https://quickchart.io/qr' +
    '?format=svg' +
    '&size=' + encodeURIComponent(size) +
    '&margin=' + encodeURIComponent(margin) +
    '&text=' + encodeURIComponent(qrText)
  );
}


/**
 * Làm sạch SVG QR trước khi nhúng vào HTML.
 */
function sanitizeQrSvg_(svgText) {
  let svg = String(svgText || '').trim();
  if (!svg) return '';

  // Bỏ XML header/doctype nếu có.
  svg = svg
    .replace(/<\?xml[\s\S]*?\?>/gi, '')
    .replace(/<!DOCTYPE[\s\S]*?>/gi, '')
    .trim();

  const start = svg.indexOf('<svg');
  const end = svg.lastIndexOf('</svg>');

  if (start < 0 || end < 0) return '';

  svg = svg.substring(start, end + 6);

  // Chặn nội dung không cần thiết.
  svg = svg
    .replace(/<script[\s\S]*?<\/script>/gi, '')
    .replace(/\son[a-z]+\s*=\s*"[^"]*"/gi, '')
    .replace(/\son[a-z]+\s*=\s*'[^']*'/gi, '');

  // Ép kích thước hiển thị ổn định trong PDF.
  svg = svg.replace(
    /<svg\b([^>]*)>/i,
    '<svg$1 width="86" height="86" style="width:86px;height:86px;display:block;background:#fff;" preserveAspectRatio="xMidYMid meet">'
  );

  return svg;
}


/**
 * Tải QR SVG từ QuickChart và trả về markup SVG nội tuyến.
 */
function buildQrInlineSvg_(qrText) {
  const url = buildVehicleQrSvgUrl_(qrText);
  if (!url) return '';

  try {
    const res = UrlFetchApp.fetch(url, {
      muteHttpExceptions: true,
      followRedirects: true,
      validateHttpsCertificates: true,
      headers: {
        'User-Agent': 'Mozilla/5.0 AppsScript QR SVG Generator'
      }
    });

    const code = res.getResponseCode();
    if (code < 200 || code >= 300) {
      throw new Error('HTTP ' + code + ' khi tải QR SVG');
    }

    const svg = sanitizeQrSvg_(res.getContentText());
    if (!svg || svg.indexOf('<svg') < 0) {
      throw new Error('QR SVG rỗng hoặc không hợp lệ');
    }

    return svg;
  } catch (err) {
    Logger.log('Không tạo được QR inline SVG: ' + errorMessage_(err));
    return '';
  }
}


function buildVehicleQrProfile_(xe, nam) {
  const qrText = buildVehicleQrText_(xe, nam);

  // Giải pháp chính: inline SVG, không dùng ảnh.
  const svgMarkup = buildQrInlineSvg_(qrText);

  // Vẫn giữ PNG data URI làm dự phòng nếu cần xem debug.
  let imageDataUri = '';
  let imageUrl = '';
  let provider = svgMarkup ? 'quickchart_svg_inline' : '';
  let lastError = '';

  if (!svgMarkup) {
    const candidates = buildVehicleQrImageUrls_(qrText);

    for (let i = 0; i < candidates.length; i++) {
      try {
        imageDataUri = fetchQrPngDataUri_(candidates[i].url);
        imageUrl = candidates[i].url;
        provider = candidates[i].provider;

        if (imageDataUri && imageDataUri.indexOf('data:image/') === 0) break;
      } catch (err) {
        lastError = candidates[i].provider + ': ' + errorMessage_(err);
        Logger.log('Lỗi tạo QR PNG dự phòng: ' + lastError);
      }
    }
  }

  return {
    text: qrText,
    openUrl: qrText,
    svgMarkup: svgMarkup,
    imageUrl: imageUrl,
    imageDataUri: imageDataUri,
    provider: provider,
    error: svgMarkup || imageDataUri ? '' : (lastError || 'Không tạo được QR')
  };
}


