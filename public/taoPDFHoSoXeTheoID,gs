/**
 * Tạo dữ liệu kỹ thuật gồm:
 * - Bảng tháng 12 cột
 * - Nhật ký BDSC chi tiết
 * - Tổng km, số chuyến, số phiếu, chi phí
 */
function buildTechnicalData_(model, idXe, nam) {
  const kmRows = (model.byXe.XE_SO_KM_THANG[idXe] || [])
    .filter(r => Number(r.Nam) === Number(nam));

  const byMonth = {};
  kmRows.forEach(r => {
    const m = Number(r.Thang);
    if (m >= 1 && m <= 12) byMonth[m] = r;
  });

  const kmThangRaw = [];
  const kmLuyKeRaw = [];
  const chuyenThangRaw = [];
  const chuyenLuyKeRaw = [];

  for (let m = 1; m <= 12; m++) {
    const r = byMonth[m];

    kmThangRaw.push(r ? valueOrNull_(r.SoKmHoatDong) : null);
    kmLuyKeRaw.push(r ? valueOrNull_(r.LuyKeKmXeChay) : null);
    chuyenThangRaw.push(r ? valueOrNull_(r.SoChuyenTrongThang) : null);
    chuyenLuyKeRaw.push(r ? valueOrNull_(r.LuyKeSoChuyen) : null);
  }

  const bdscSourceRows = (model.byXe.XE_BAODUONG_SUACHUA[idXe] || [])
    .filter(r => yearOf_(r.NgayThucHien) === Number(nam))
    .sort((a, b) => dateMs_(a.NgayThucHien) - dateMs_(b.NgayThucHien));

  const counters = { BD: 0, SC: 0, CT: 0 };
  const bdscAnnotated = bdscSourceRows.map(r => {
    const type = bdscType_(r.LoaiPhieu);
    counters[type] = (counters[type] || 0) + 1;

    const code = type + String(counters[type]).padStart(2, '0');

    return {
      source: r,
      type: type,
      code: code,
      month: monthOf_(r.NgayThucHien),
      period: formatWorkPeriod_(r.NgayThucHien, r.NgayKetThuc),
      place: displayDiaDiemSuaChua_(model, r.Ref_DonViSuaChua)
    };
  });

  const baoDuong = new Array(12).fill('');
  const suaChua = new Array(12).fill('');
  const caiTao = new Array(12).fill('');

  bdscAnnotated.forEach(item => {
    const m = item.month;
    if (m < 1 || m > 12) return;

    if (item.type === 'BD') {
      baoDuong[m - 1] = appendCell_(baoDuong[m - 1], item.code);
    } else if (item.type === 'CT') {
      caiTao[m - 1] = appendCell_(caiTao[m - 1], item.code);
    } else {
      suaChua[m - 1] = appendCell_(suaChua[m - 1], item.code);
    }
  });

  const monthRows = [
    {
      tt: '1',
      noiDung: 'Km xe chạy trong tháng',
      values: kmThangRaw.map(v => formatNumberCell_(v)),
      total: formatNumberCell_(sumNumbers_(kmThangRaw)),
