/**
 * Tách Google Drive File ID từ các dạng link phổ biến.
 */
function extractDriveFileId_(url) {
  url = String(url || '').trim();
  if (!url) return '';

  let m = url.match(/\/d\/([a-zA-Z0-9_-]+)/);
  if (m && m[1]) return m[1];

  m = url.match(/[?&]id=([a-zA-Z0-9_-]+)/);
  if (m && m[1]) return m[1];

  return '';
}


