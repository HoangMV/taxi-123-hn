/**
 * Tạo PDF hồ sơ điện tử cho 1 xe theo ID_Xe.
 *
 * @param {string} idXe
 * @param {number=} nam
 * @return {Object}
 */
function taoPDFHoSoXeTheoID(idXe, nam) {
  if (!idXe) throw new Error('Thiếu ID_Xe');

  nam = Number(nam || new Date().getFullYear());

  const ss = getSpreadsheet_();
  const xeSheet = mustGetSheet_(ss, CONFIG_HOSO_XE.SHEETS.XE);
  ensureColumns_(xeSheet, CONFIG_HOSO_XE.XE_PDF_COLUMNS);

  const model = loadModel_();
  const xe = model.index.XE[String(idXe).trim()];

  if (!xe) {
    throw new Error('Không tìm thấy xe có ID_Xe = ' + idXe);
  }

  try {
    const result = createVehicleProfilePdf_(model, xe, nam);

    updateXePdfFields_(xe._rowNumber, {
      FilePDFHoSoXe: result.publicViewUrl || result.url,
      IdFilePDFHoSoXe: result.fileId,
      LinkTaiPDFHoSoXe: result.downloadUrl,
      NamPDFHoSoXe: nam,
      NgayTaoPDFHoSoXe: new Date(),
      TrangThaiTaoPDFHoSoXe: 'Đã tạo',
      GhiChuPDFHoSoXe: 'Tạo thành công: ' + result.fileName
    });

    return result;

  } catch (err) {
    updateXePdfFields_(xe._rowNumber, {
      TrangThaiTaoPDFHoSoXe: 'Lỗi',
      GhiChuPDFHoSoXe: errorMessage_(err)
    });

    throw err;
  }
}


