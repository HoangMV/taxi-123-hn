        '&chl=' + encodeURIComponent(qrText)
    }
  ];
}


/**
 * Tải ảnh QR và chuyển thành data URI base64.
 *
 * Đây là điểm xử lý dứt điểm:
 * - PDF tạo từ HTML không ổn định với ảnh ngoài.
 * - Do đó phải tải ảnh bằng UrlFetchApp rồi nhúng base64 vào HTML.
 */
function fetchQrPngDataUri_(url) {
  url = String(url || '').trim();
  if (!url) return '';

  const res = UrlFetchApp.fetch(url, {
    muteHttpExceptions: true,
    followRedirects: true,
    validateHttpsCertificates: true,
    headers: {
      'User-Agent': 'Mozilla/5.0 AppsScript QR Generator'
    }
  });

  const code = res.getResponseCode();
  if (code < 200 || code >= 300) {
    throw new Error('HTTP ' + code + ' khi tải QR');
  }

  const bytes = res.getContent();
  if (!bytes || bytes.length < 300) {
    throw new Error('Ảnh QR trả về rỗng hoặc quá nhỏ');
  }

  const blob = res.getBlob();
  let contentType = String(blob.getContentType() || '').toLowerCase();

  /*
   * Một số dịch vụ trả về content-type thiếu/chưa chuẩn.
   * Với PDF, dùng image/png là ổn định nhất.
   */
  if (!contentType || contentType.indexOf('image/') !== 0) {
    contentType = 'image/png';
  }

  const base64 = Utilities.base64Encode(bytes);
  return 'data:' + contentType + ';base64,' + base64;
}


