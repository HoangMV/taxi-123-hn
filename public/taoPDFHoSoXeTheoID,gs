/**
 * Tạo PDF và trả thông tin file.
 */
function createVehicleProfilePdf_(model, xe, nam) {
  const data = buildVehicleProfileData_(model, xe, nam);

  const template = HtmlService.createTemplateFromFile('VehicleProfile');
  template.data = data;

  const html = template.evaluate().getContent();

  const bienSo = cleanFileName_(xe.BienSo || xe.ID_Xe);
  const idXe = cleanFileName_(xe.ID_Xe);
  const fileName = 'HOSO_DIENTU_XE_' + bienSo + '_' + nam + '.pdf';

  const folderName = idXe + '_' + bienSo;
  const folderPath =
    CONFIG_HOSO_XE.ROOT_FOLDER_PATH + '/' +
    folderName + '/' +
    CONFIG_HOSO_XE.PROFILE_SUBFOLDER;

  const folder = getOrCreateFolderByPath_(folderPath);

  trashFilesByName_(folder, fileName);

  const htmlBlob = Utilities.newBlob(
    html,
    'text/html',
    fileName.replace('.pdf', '.html')
  );

  const pdfBlob = htmlBlob.getAs(MimeType.PDF).setName(fileName);
  const file = folder.createFile(pdfBlob);

  // Bắt buộc public để người quét QR xem/tải không cần đăng nhập Google.
  makeDriveFilePublic_(file);

  const fileId = file.getId();

  return {
    fileId: fileId,
    fileName: fileName,
    url: buildDriveViewUrl_(fileId),
    publicViewUrl: buildDriveViewUrl_(fileId),
    downloadUrl: buildDriveDownloadUrl_(fileId)
  };
}




/**
 * Kiểm tra giá trị có phải placeholder không.
 * Các chuỗi bắt đầu bằng "Nhập ..." sẽ không được đưa vào PDF.
 */
function isPlaceholderText_(value) {
  const s = String(value || '').trim();
  if (!s) return true;

  const t = normalizeText_(s);
  return (
    t === '-' ||
    t === '—' ||
    t.indexOf('nhap ') === 0 ||
    t.indexOf('nhap dia chi') >= 0 ||
    t.indexOf('nhap so') >= 0 ||
    t.indexOf('chua co') >= 0 ||
    t.indexOf('chua nhap') >= 0
  );
}


/**
 * Lấy text đầu tiên hợp lệ, bỏ qua chuỗi placeholder.
 */
function firstRealText_() {
  for (let i = 0; i < arguments.length; i++) {
    const s = String(arguments[i] || '').trim();
    if (s && !isPlaceholderText_(s)) return s;
  }
  return '';
}


/**
 * Lấy bản ghi DONVI theo nhiều khả năng:
 * - Ref trực tiếp là ID_DonVi.
 * - Ref là MaDonVi.
 * - Ref là MaSoThue.
 */
function findDonViRow_(model, ref) {
  const key = String(ref || '').trim();
  if (!key) return null;

  if (model.index && model.index.DONVI && model.index.DONVI[key]) {
    return model.index.DONVI[key];
  }

  const rows = model.tables && model.tables.DONVI ? model.tables.DONVI.rows : [];
  const keyNorm = normalizeText_(key);

  for (let i = 0; i < rows.length; i++) {
    const r = rows[i];
    if (
      normalizeText_(r.ID_DonVi) === keyNorm ||
      normalizeText_(r.MaDonVi) === keyNorm ||
      normalizeText_(r.MaSoThue) === keyNorm ||
      normalizeText_(r.TenDonVi) === keyNorm ||
      normalizeText_(r.TenVietTat) === keyNorm
    ) {
      return r;
    }
  }

  return null;
}


/**
 * Chọn đơn vị hiển thị trên hồ sơ xe.
 *
 * Thứ tự ưu tiên:
 * 1. CONFIG_CONGTY_HOSO_XE.DEFAULT_DONVI_ID nếu có cấu hình.
 * 2. XE[Ref_DonViQuanLyHienTai].
 * 3. XE[Ref_DonViChuQuan].
 * 4. Dòng DONVI đầu tiên có trạng thái hoạt động/hợp lệ.
 * 5. Dòng DONVI đầu tiên trong bảng.
 */
function pickCompanyDonViRow_(model, xe) {
  const rows = model.tables && model.tables.DONVI ? model.tables.DONVI.rows : [];

  // 1. YÊU CẦU CHỐT: lấy theo đơn vị chủ quản của xe.
  const byChuQuan = findDonViRow_(model, xe.Ref_DonViChuQuan);
  if (byChuQuan) return byChuQuan;

  // 2. Nếu xe chưa có Ref_DonViChuQuan thì dùng đơn vị mặc định trong cấu hình.
  const configured = findDonViRow_(model, CONFIG_CONGTY_HOSO_XE.DEFAULT_DONVI_ID);
  if (configured) return configured;

  // 3. Ref_DonViQuanLyHienTai chỉ dùng dự phòng, không phải nguồn chính để in đầu hồ sơ.
  const byQuanLy = findDonViRow_(model, xe.Ref_DonViQuanLyHienTai);
  if (byQuanLy) return byQuanLy;

  // 4. Dự phòng: lấy dòng DONVI đang hoạt động/hợp lệ đầu tiên.
  for (let i = 0; i < rows.length; i++) {
    const st = normalizeText_(rows[i].TrangThai);
    if (
      !st ||
      st.includes('dang') ||
      st.includes('hoat dong') ||
      st.includes('hieu luc') ||
      st.includes('jfg5cz14')
    ) {
      return rows[i];
    }
  }

  // 5. Dự phòng cuối.
  return rows.length ? rows[0] : null;
}


/**
 * Lấy thông tin công ty để truyền sang VehicleProfile.html.
 *
 * Kết quả trả về hỗ trợ các trường:
 * - data.company.tenCongTy
 * - data.company.diaChi
 * - data.company.soDangKyKinhDoanh
 * - data.company.soDienThoai
 * - data.meta.diaChiCongTy
 * - data.meta.soDangKyKinhDoanh
 * - data.meta.soDienThoai
 */
function getCompanyProfile_(model, xe) {
  model = model || {};
  xe = xe || {};

  const donVi = pickCompanyDonViRow_(model, xe) || {};

  const tenCongTy = firstRealText_(
    donVi.TenDonVi,
    donVi.TenVietTat,
    CONFIG_CONGTY_HOSO_XE.TEN_CONG_TY
  );

  const diaChi = firstRealText_(
    donVi.DiaChi,
    donVi.DiaChiTruSo,
    donVi.DiaChiCongTy,
    CONFIG_CONGTY_HOSO_XE.DIA_CHI
  );

  const soDangKyKinhDoanh = firstRealText_(
    donVi.MaSoThue,
    donVi.SoDangKyKinhDoanh,
    donVi.MaDonVi,
    CONFIG_CONGTY_HOSO_XE.SO_DANG_KY_KINH_DOANH
  );

  const soDienThoai = firstRealText_(
    donVi.SoDienThoai,
    donVi.DienThoai,
    donVi.Phone,
    CONFIG_CONGTY_HOSO_XE.SO_DIEN_THOAI
  );

  return {
    idDonVi: String(donVi.ID_DonVi || '').trim(),
    maDonVi: String(donVi.MaDonVi || '').trim(),
    tenCongTy: tenCongTy,
    diaChi: diaChi,
    soDangKyKinhDoanh: soDangKyKinhDoanh,
    maSoThue: soDangKyKinhDoanh,
    soDienThoai: soDienThoai,
