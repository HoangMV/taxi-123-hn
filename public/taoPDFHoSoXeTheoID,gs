    {
      tt: '2',
      noiDung: 'Số chuyến trong tháng',
      values: chuyenThangRaw.map(v => formatNumberCell_(v)),
      total: formatNumberCell_(sumNumbers_(chuyenThangRaw)),
      thoiGian: '',
      diaDiem: ''
    },
    {
      tt: '',
      noiDung: 'Số chuyến xe lũy kế',
      values: chuyenLuyKeRaw.map(v => formatNumberCell_(v)),
      total: formatNumberCell_(lastNumber_(chuyenLuyKeRaw)),
      thoiGian: '',
      diaDiem: ''
    },
    {
      tt: '3',
      noiDung: 'Bảo dưỡng',
      values: baoDuong,
      total: countType_(bdscAnnotated, 'BD'),
      thoiGian: collectPeriods_(bdscAnnotated, 'BD'),
      diaDiem: collectPlacesFromAnnotated_(bdscAnnotated, 'BD')
    },
    {
      tt: '4',
      noiDung: 'Sửa chữa',
      values: suaChua,
      total: countType_(bdscAnnotated, 'SC'),
      thoiGian: collectPeriods_(bdscAnnotated, 'SC'),
      diaDiem: collectPlacesFromAnnotated_(bdscAnnotated, 'SC')
    },
    {
      tt: '5',
      noiDung: 'Cải tạo',
      values: caiTao,
      total: countType_(bdscAnnotated, 'CT'),
      thoiGian: collectPeriods_(bdscAnnotated, 'CT'),
      diaDiem: collectPlacesFromAnnotated_(bdscAnnotated, 'CT')
    }
  ];

  const bdscRows = bdscAnnotated
    .slice()
    .sort((a, b) => dateMs_(b.source.NgayThucHien) - dateMs_(a.source.NgayThucHien))
    .map(item => {
