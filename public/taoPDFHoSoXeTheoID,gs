/**
 * Đọc sheet thành object theo header.
 */
function readSheet_(ss, sheetName) {
  const sh = ss.getSheetByName(sheetName);

  if (!sh) {
    return { sheet: null, headers: [], rows: [] };
  }

  const range = sh.getDataRange();
  const values = range.getValues();

  if (!values.length) {
    return { sheet: sh, headers: [], rows: [] };
  }

  const headers = values[0].map(h => String(h || '').trim());
  const rows = [];

  for (let r = 1; r < values.length; r++) {
    const obj = {
      _rowNumber: r + 1,
      _sheetName: sheetName
    };

    headers.forEach((h, c) => {
      if (h) obj[h] = values[r][c];
    });

    rows.push(obj);
  }

  return { sheet: sh, headers, rows };
}


/**
 * Ghi thông tin PDF vào chính dòng xe.
 */
function updateXePdfFields_(rowNumber, data) {
  const ss = getSpreadsheet_();
  const sh = mustGetSheet_(ss, CONFIG_HOSO_XE.SHEETS.XE);
  const headerMap = ensureColumns_(sh, CONFIG_HOSO_XE.XE_PDF_COLUMNS);

  Object.keys(data).forEach(k => {
    const col = headerMap[k];
    if (col) sh.getRange(rowNumber, col).setValue(data[k]);
  });
}


/**
 * Bảo đảm sheet có đủ cột cần thiết.
 */
function ensureColumns_(sh, columns) {
  const lastCol = Math.max(sh.getLastColumn(), 1);
  let headers = sh.getRange(1, 1, 1, lastCol).getValues()[0].map(v => String(v || '').trim());

  columns.forEach(colName => {
    if (!headers.includes(colName)) {
      sh.getRange(1, headers.length + 1).setValue(colName);
      headers.push(colName);
    }
  });

  const map = {};
  headers.forEach((h, i) => {
    if (h) map[h] = i + 1;
  });

  return map;
}


/**
 * Lấy Spreadsheet.
 */
function getSpreadsheet_() {
  if (CONFIG_HOSO_XE.SPREADSHEET_ID) {
    return SpreadsheetApp.openById(CONFIG_HOSO_XE.SPREADSHEET_ID);
  }

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  if (!ss) {
    throw new Error('Không mở được Spreadsheet. Hãy gắn script vào Google Sheet hoặc điền CONFIG_HOSO_XE.SPREADSHEET_ID.');
  }

  return ss;
}


function mustGetSheet_(ss, sheetName) {
  const sh = ss.getSheetByName(sheetName);
  if (!sh) throw new Error('Không tìm thấy sheet: ' + sheetName);
  return sh;
}


/**
 * Tạo hoặc lấy folder theo đường dẫn.
 */
function getOrCreateFolderByPath_(path) {
  const parts = String(path || '')
    .split('/')
    .map(s => s.trim())
    .filter(Boolean);

  let folder = DriveApp.getRootFolder();

  parts.forEach(name => {
    const found = folder.getFoldersByName(name);
    folder = found.hasNext() ? found.next() : folder.createFolder(name);
  });

  return folder;
}


function trashFilesByName_(folder, fileName) {
  const oldFiles = folder.getFilesByName(fileName);
  while (oldFiles.hasNext()) {
    oldFiles.next().setTrashed(true);
  }
}


function sortRowsByDatesDesc_(rows, dateFields) {
  return (rows || [])
    .slice()
    .sort((a, b) => {
      const da = maxDateMs_(a, dateFields);
      const db = maxDateMs_(b, dateFields);
      if (da !== db) return db - da;
      return Number(b._rowNumber || 0) - Number(a._rowNumber || 0);
    });
}


/**
 * Chọn bản ghi mới nhất/đang hiệu lực.
 */
function pickLatest_(rows, dateFields, statusField) {
  rows = rows || [];
  if (!rows.length) return {};

  const arr = rows.slice();

  arr.sort((a, b) => {
    const sa = statusScore_(a[statusField]);
    const sb = statusScore_(b[statusField]);
    if (sa !== sb) return sb - sa;

    const da = maxDateMs_(a, dateFields);
    const db = maxDateMs_(b, dateFields);
    if (da !== db) return db - da;

    return Number(b._rowNumber || 0) - Number(a._rowNumber || 0);
  });

  return arr[0] || {};
}


function statusScore_(s) {
  const t = normalizeText_(s);
  if (!t) return 0;

  if (
    t.includes('dang hieu luc') ||
    t.includes('con hieu luc') ||
    t.includes('dang the chap') ||
    t.includes('dang hoat dong') ||
    t.includes('con du no') ||
    t.includes('da nhap') ||
    t.includes('hoan thanh')
  ) {
    return 3;
  }

  if (
    t.includes('sap het') ||
    t.includes('canh bao')
  ) {
    return 2;
  }

  if (
    t.includes('het hieu luc') ||
    t.includes('het han') ||
    t.includes('huy') ||
    t.includes('ngung') ||
    t.includes('da tai tuc')
  ) {
    return -1;
  }

  return 1;
}


function statusByDate_(value) {
  const d = asDate_(value);
  if (!d) return '';

  const today = new Date();
  today.setHours(0, 0, 0, 0);

  const diffDays = Math.floor((d.getTime() - today.getTime()) / 86400000);

  if (diffDays < 0) return 'Đã hết hạn';
  if (diffDays <= 30) return 'Sắp hết hạn';
  return 'Còn hiệu lực';
}


function warningLevelFromText_(text) {
  const t = normalizeText_(text);
  if (t.includes('het han') || t.includes('thieu') || t.includes('qua han')) return 'Đỏ';
  if (t.includes('sap') || t.includes('canh bao') || t.includes('chua')) return 'Vàng';
  return 'Thông tin';
}


function indexBy_(rows, key) {
  const out = {};
  (rows || []).forEach(r => {
    const v = String(r[key] || '').trim();
    if (v) out[v] = r;
  });
  return out;
}


function indexByNormalized_(rows, key) {
  const out = {};
  (rows || []).forEach(r => {
    const v = normalizeKey_(r[key]);
    if (v) out[v] = r;
  });
  return out;
}


function groupBy_(rows, key) {
  const out = {};
  (rows || []).forEach(r => {
    const v = String(r[key] || '').trim();
    if (!v) return;
    if (!out[v]) out[v] = [];
    out[v].push(r);
  });
  return out;
}


