    {
      tt: '',
      noiDung: 'Km xe chạy lũy kế',
      values: kmLuyKeRaw.map(v => formatNumberCell_(v)),
      total: formatNumberCell_(lastNumber_(kmLuyKeRaw)),
      thoiGian: '',
      diaDiem: ''
