        '?format=png' +
        '&size=' + encodeURIComponent(size) +
        '&margin=' + encodeURIComponent(margin) +
        '&text=' + encodeURIComponent(qrText)
    },
    {
      provider: 'qrserver_png',
      url:
        'https://api.qrserver.com/v1/create-qr-code/' +
        '?size=' + encodeURIComponent(size + 'x' + size) +
        '&margin=' + encodeURIComponent(margin) +
        '&format=png' +
        '&data=' + encodeURIComponent(qrText)
