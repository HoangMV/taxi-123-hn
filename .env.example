# ID Google Spreadsheet chứa các tab dữ liệu nghiệp vụ.
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Email service account đã được share quyền xem Google Sheet.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private key service account. Nếu để trong một dòng, giữ nguyên ký tự \n.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Range mặc định khi đọc từng tab. Có thể để trống để dùng A:ZZ.
GOOGLE_SHEETS_DEFAULT_RANGE=A:ZZ

# Map tên bảng trong code sang tên tab Google Sheet nếu khác nhau. Để trống nếu giống nhau.
GOOGLE_SHEETS_TABLE_MAP={}

# Map range riêng cho từng bảng nếu muốn tối ưu tốc độ hoặc giới hạn cột.
GOOGLE_SHEETS_RANGE_MAP={}

# Bảng mặc định dự phòng cho runtime config public, có thể để trống.
REACT_APP_DEFAULT_TABLE=

# Đường dẫn API backend public cho React và HTML standalone.
REACT_APP_API_BASE_URL=/api
