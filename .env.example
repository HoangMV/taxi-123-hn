# ID của ứng dụng AppSheet dùng làm nguồn dữ liệu.
REACT_APP_APP_ID=your-appsheet-app-id

# Access Key chỉ để backend proxy đọc từ môi trường server.
# Không ghi giá trị thật vào file public, runtime-config.js hoặc source frontend.
REACT_APP_ACCESS_KEY=your-appsheet-access-key

# Đường dẫn proxy để frontend gọi AppSheet mà không lộ Access Key.
REACT_APP_API_PROXY_URL=/api/appsheet

# Cụm máy chủ AppSheet, thường là `www`.
REACT_APP_REGION=www

# Bảng mặc định dự phòng cho các màn cần đọc bảng cấu hình.
# Có thể để trống nếu chưa dùng.
REACT_APP_DEFAULT_TABLE=

# Danh sách bảng để script `npm run schema:appsheet` đọc schema.
# Nếu có `NHANSU_KYQUY`, script sẽ tự thêm `DONVI` và `NHANSU` để resolve các cột Ref liên quan.
REACT_APP_SCHEMA_TABLES=
